#!/usr/bin/env bash
# Git post-commit hook — delegates to graph-index-hook.sh for code graph reindex.
# This file lives in scripts/ and is used via core.hooksPath, so it works
# identically in both the main repo and worktrees.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
[ -x "$SCRIPT_DIR/graph-index-hook.sh" ] && "$SCRIPT_DIR/graph-index-hook.sh" &
